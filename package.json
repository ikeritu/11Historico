{
  "name": "futbol11",
  "private": true,
  "version": "0.21.0-h",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "audit:balance": "vite build --ssr scripts/balanceAuditCli.ts --outDir .audit-dist --emptyOutDir false && node .audit-dist/balanceAuditCli.js",
    "audit:balance:100": "vite build --ssr scripts/balanceAuditCli.ts --outDir .audit-dist --emptyOutDir false && node .audit-dist/balanceAuditCli.js --sims=100 --profile=balanced --difficulty=normal --range=all",
    "audit:balance:json": "vite build --ssr scripts/balanceAuditCli.ts --outDir .audit-dist --emptyOutDir false && node .audit-dist/balanceAuditCli.js --json --out=reports/balance_cli_latest.json --csv=reports/balance_cli_latest.csv",
    "audit:copa:100": "vite build --ssr scripts/balanceAuditCli.ts --outDir .audit-dist --emptyOutDir false && node .audit-dist/balanceAuditCli.js --sims=100 --profile=balanced --difficulty=normal --range=all --cup-report"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
